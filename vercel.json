{
  "version": 2,
  "routes": [{ "src": "/(.*)", "dest": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Permissions-Policy", "value": "camera=*" },
        { "key": "Feature-Policy", "value": "camera *" }
      ]
    }
  ]
}

